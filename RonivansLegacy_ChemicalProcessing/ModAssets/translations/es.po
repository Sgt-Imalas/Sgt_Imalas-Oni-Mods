msgstr "<link=\"FRIDGELARGERED\">Refrigerador Doméstico Rojo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_STICKERS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_STICKERS.DESC"
msgid "A variant of the Household Fridge that has been plastered with a large variety of stickers"
msgstr "Una variante del Refrigerador Doméstico que ha sido plagada con una gran variedad de pegatinas"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_STICKERS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_STICKERS.NAME"
msgid "<link=\"FRIDGELARGESTICKERS\">Stickered Household Fridge</link>"
msgstr "<link=\"FRIDGELARGESTICKERS\">Refrigerador Doméstico con Pegatinas</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_YELLOW.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_YELLOW.DESC"
