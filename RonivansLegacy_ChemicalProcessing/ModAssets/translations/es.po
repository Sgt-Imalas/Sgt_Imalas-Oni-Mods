msgstr "<link=\"CHEMICALGLASSFOUNDRY\">Fundición de Vidrio</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_LIQUID_BOILER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_LIQUID_BOILER.DESC"
