#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.DESC"
msgid "Solar panels convert high intensity sunlight into power and produce zero waste."
msgstr "Los paneles solares convierten la luz solar de alta intensidad en energía y no producen residuos."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.EFFECT"
msgid ""
"Converts <link=\"LIGHT\">Sunlight</link> into electrical <link=\"POWER\">Power</link>.\n"
"\n"
"Can be rotated."
msgstr ""
"Convierte la <link=\"LIGHT\">Luz Solar</link> en <link=\"POWER\">Energía</link> eléctrica.\n"
"\n"
"Se puede rotar."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLARPANEL.NAME"
msgid "<link=\"CUSTOMSOLARPANEL\">Custom Solar Panel</link>"
msgstr "<link=\"CUSTOMSOLARPANEL\">Panel Solar Personalizado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLIDGENERATOR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMSOLIDGENERATOR.DESC"
msgid "A small, custom Refined Carbon generator. This rather versatile generator has piped outputs."
msgstr "Un pequeño generador de Carbón Refinado personalizado. Este generador bastante versátil tiene salidas entubadas."

