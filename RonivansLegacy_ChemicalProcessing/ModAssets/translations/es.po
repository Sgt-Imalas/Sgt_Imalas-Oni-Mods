msgstr "<link=\"WALLLIQUIDTANK\">Depósito de Líquido de Pared</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.DESC"
msgid "Wood work used to decorate the ceilings of rooms. Increases Decor, contributing to Morale."
msgstr "Trabajo en madera utilizado para decorar los techos de las habitaciones. Aumenta el Decorado, contribuyendo a la Moral."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.EFFECT"
msgid "This ceiling is a beautiful masonry and wood work, but serves only as a decorative purpose."
msgstr "Este techo es un hermoso trabajo de mampostería y madera, pero solo sirve como un propósito decorativo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCEILING.NAME"
msgid "Wooden Ceiling"
msgstr "Techo de Madera"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.DESC"
msgid "Tiles composed of minerals and wooden adornments."
msgstr "Baldosas compuestas de minerales y adornos de madera."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.EFFECT"
msgid ""
"Used to build the walls and floors of rooms. Increases Decor, contributing to Morale.\n"
"Its composition gives it excellent insulation."
msgstr ""
"Se utiliza para construir las paredes y los suelos de las habitaciones. Aumenta el Decorado, contribuyendo a la Moral.\n"
"Su composición le confiere un excelente aislamiento."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCOMPOSITIONTILE.NAME"
msgid "<link=\"WOODENCOMPOSITIONTILE\">Wood Composite Tile</link>"
msgstr "<link=\"WOODENCOMPOSITIONTILE\">Baldosa Compuesta de Madera</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.DESC"
msgid "A wooden arch used to decorate the ceiling corners of rooms. Increases Decor, contributing to Morale."
msgstr "Un arco de madera utilizado para decorar las esquinas del techo de las habitaciones. Aumenta el Decorado, contribuyendo a la Moral."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.EFFECT"
msgid "This corner ceiling arch is beautiful masonry and wood work, but serves only as a decorative purpose."
msgstr "Este arco de techo de esquina es un hermoso trabajo de mampostería y madera, pero solo sirve como un propósito decorativo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENCORNERARCH.NAME"
msgid "Wooden Corner Arch"
msgstr "Arco de Esquina de Madera"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.DESC"
msgid "Building with wooden airflow tiles promotes better gas circulation within a colony."
msgstr "Construir con baldosas de madera para flujo de aire promueve una mejor circulación de gas dentro de una colonia."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.EFFECT"
msgid ""
"A semipermeable wooden tile, used to build walls and floors of rooms. \n"
"\n"
"Blocks Liquid flow without obstructing Gas."
msgstr ""
"Una baldosa de madera semipermeable, utilizada para construir paredes y suelos de habitaciones. \n"
"\n"
"Bloquea el flujo de Líquido sin obstruir el Gas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENGASTILE.NAME"
msgid "<link=\"WOODENGASTILE\">Wooden Airflow Tile</link>"
msgstr "<link=\"WOODENGASTILE\">Baldosa de Madera para Flujo de Aire</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.DESC"
msgid "Building with hollow wooden tiles promotes better gas circulation within a colony."
msgstr "Construir con baldosas de madera huecas promueve una mejor circulación de gas dentro de una colonia."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.EFFECT"
msgid ""
"A permeable wooden tile, used to build walls and floors of rooms. \n"
"\n"
"Allows the flow of both liquid and Gas."
msgstr ""
"Una baldosa de madera permeable, utilizada para construir paredes y suelos de habitaciones. \n"
"\n"
"Permite el flujo tanto de líquido como de Gas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.WOODENMESHTILE.NAME"
msgid "<link=\"WOODENMESHTILE\">Wooden Mesh Tile</link>"
msgstr "<link=\"WOODENMESHTILE\">Baldosa de Malla de Madera</link>"

