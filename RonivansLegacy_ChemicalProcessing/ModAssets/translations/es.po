#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_YELLOW.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_YELLOW.NAME"
msgid "<link=\"FRIDGELARGEYELLOW\">Yellow Household Fridge</link>"
msgstr "<link=\"FRIDGELARGEYELLOW\">Refrigerador Doméstico Amarillo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.NAME"
msgid "<link=\"AIOFRIDGELARGE\">Household Fridge</link>"
msgstr "<link=\"AIOFRIDGELARGE\">Refrigerador Doméstico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.DESC"
msgid "A sturdy and durable ladder wrought from refined metals."
msgstr "Una escalera resistente y duradera forjada con metales refinados."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.EFFECT"
msgid "Increases Duplicant climbing speed."
msgstr "Aumenta la velocidad de escalada de los Duplicantes."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.NAME"
msgid "<link=\"AIOMETALLADDER\">Metal Ladder</link>"
msgstr "<link=\"AIOMETALLADDER\">Escalera de Metal</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.DESC"
msgid "A fine tile made from glazed stones."
msgstr "Una baldosa fina hecha de piedras esmaltadas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.EFFECT"
msgid ""
"Used as floor and wall tile to build rooms.\n"
"\n"
"Significantly increases Duplicant runspeed."
msgstr ""
"Se utiliza como baldosa de suelo y pared para construir habitaciones.\n"
"\n"
"Aumenta significativamente la velocidad al correr de los Duplicantes."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_MOSAICTILE.NAME"
msgid "<link=\"AIOMOSAICTILE\">Mosaic Tile</link>"
msgstr "<link=\"AIOMOSAICTILE\">Baldosa de Mosaico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.DESC"
msgid "Be careful with splinters!"
msgstr "¡Ten cuidado con las astillas!"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.EFFECT"
msgid "A pretty wooden door that encloses areas without blocking Liquid or Gas flow. Sets Duplicant Access Permissions for area restriction."
msgstr "Una bonita puerta de madera que encierra áreas sin bloquear el flujo de Líquidos o Gases. Establece los Permisos de Acceso de Duplicantes para la restricción de áreas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_WOODENDOOR.NAME"
msgid "<link=\"AIOWOODENDOOR\">Wooden Door</link>"
msgstr "<link=\"AIOWOODENDOOR\">Puerta de Madera</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.DESC"
msgid "An advanced biological vat that grows algae. Due to the controlled atmospheric condition, this algae formation produces oxygen more efficiently than the standard terrarium. This unit also uses advanced filter to extract Carbon Dioxide from its surroundings, albeit its not necessary for it to function."
msgstr ""
"Una cuba biológica avanzada que cultiva algas. Debido a la condición atmosférica controlada, esta formación de algas produce oxígeno de manera más eficiente que el terrario estándar. Esta unidad también utiliza un filtro avanzado para extraer Dióxido de Carbono de su entorno, aunque no es necesario para que funcione."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.EFFECT"
msgid "Algae patch needs <link=\"WATER\">Water</link> to grow, producing a fair amount of clean <link=\"OXYGEN\">Oxygen</link> as result of its biological functions. Excess water is expelled in the form of <link=\"DIRTYWATER\">Polluted Water</link>."
msgstr "El parche de algas necesita <link=\"WATER\">Agua</link> para crecer, produciendo una buena cantidad de <link=\"OXYGEN\">Oxígeno</link> limpio como resultado de sus funciones biológicas. El exceso de agua se expulsa en forma de <link=\"DIRTYWATER\">Agua Contaminada</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.ALGAEVAT.NAME"
msgid "<link=\"ALGAEVAT\">Algae Vat</link>"
msgstr "<link=\"ALGAEVAT\">Cuba de Algas</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.DESC"
msgid "A wide, automated biological tank design to grow organic masses of algae."
msgstr "Un tanque biológico ancho y automatizado diseñado para cultivar masas orgánicas de algas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.EFFECT"
msgid ""
"Grows <link=\"ALGAE\">Algae</link> using a constant supply of  <link=\"LIQUIDVEGEOIL\">Vegetable Oil</link> that serves as serves as nourishment for the photosynthetic organisms within.\n"
"Requires <link=\"LIGHT\">Light</link> and a strict control of <link=\"HEAT\">Temperature</link> as to provide proper environment for the production."
msgstr ""
"Cultiva <link=\"ALGAE\">Algas</link> utilizando un suministro constante de <link=\"LIQUIDVEGEOIL\">Aceite Vegetal</link> que sirve como nutrición para los organismos fotosintéticos en su interior.\n"
"Requiere <link=\"LIGHT\">Luz</link> y un control estricto de la <link=\"HEAT\">Temperatura</link> para proporcionar el entorno adecuado para la producción."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ALGAEGROWINGBASIN.NAME"
msgid "<link=\"BIOCHEMISTRYALGAEGROWINGBASIN\">Algae Growing Basin</link>"
msgstr "<link=\"BIOCHEMISTRYALGAEGROWINGBASIN\">Cuenca de Cultivo de Algas</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.DESC"
msgid "Anaerobic digestion is processes by which microorganisms break down biodegradable organic materials in the absence of oxygen."
msgstr "La digestión anaeróbica es el proceso mediante el cual los microorganismos descomponen materiales orgánicos biodegradables en ausencia de oxígeno."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.EFFECT"
msgid ""
"Breaks down most basic <link=\"FOOD\">Food</link> stored within to  <link=\"METHANE\">Natural Gas</link>\n"
"The amount produced depends of the ingredient choosen."
msgstr ""
"Descompone la <link=\"FOOD\">Comida</link> más básica almacenada en su interior en <link=\"METHANE\">Gas Natural</link>.\n"
"La cantidad producida depende del ingrediente elegido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_ANAEROBICDIGESTER.NAME"
msgid "<link=\"BIOCHEMISTRYANAEROBICDIGESTER\">Anaerobic Digester</link>"
msgstr "<link=\"BIOCHEMISTRYANAEROBICDIGESTER\">Digestor Anaeróbico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.DESC"
msgid "An advanced power generator that uses biofuel. Has a built-in scrubber system that allows it to produce no gaseous exhaust."
msgstr "Un generador de energía avanzado que utiliza biocombustible. Tiene un sistema de depuración incorporado que le permite no producir gases de escape."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.EFFECT"
msgid ""
"Converts <link=\"LIQUIDBIODIESEL\">Renewable Diesel</link> into electrical <link=\"POWER\">Power</link>.\n"
"\n"
"Produces only <link=\"DIRTYWATER\">Polluted Water</link>."
msgstr ""
"Convierte <link=\"LIQUIDBIODIESEL\">Diésel Renovable</link> en <link=\"POWER\">Energía</link> eléctrica.\n"
"\n"
"Solo produce <link=\"DIRTYWATER\">Agua Contaminada</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELGENERATOR.NAME"
msgid "<link=\"BIOCHEMISTRYBIODIESELGENERATOR\">Eco Diesel Generator</link>"
msgstr "<link=\"BIOCHEMISTRYBIODIESELGENERATOR\">Generador Eco Diésel</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.DESC"
msgid "A refinery capable of transesterification of organic oils into a mix of mono-alkyl esters of long chain fatty acids."
msgstr "Una refinería capaz de realizar la transesterificación de aceites orgánicos en una mezcla de ésteres monoalquílicos de ácidos grasos de cadena larga."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.EFFECT"
msgid "Transesterify <link=\"LIQUIDBIODIESEL\">Renewable Diesel</link> from <link=\"LIQUIDVEGEOIL\">Vegetable Oil</link> and <link=\"ETHANOL\">Ethanol</link>."
msgstr "Transesterifica <link=\"LIQUIDBIODIESEL\">Diésel Renovable</link> a partir de <link=\"LIQUIDVEGEOIL\">Aceite Vegetal</link> y <link=\"ETHANOL\">Etanol</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIODIESELREFINERY.NAME"
msgid "<link=\"BIOCHEMISTRYBIODIESELREFINERY\">Biodiesel Refinery</link>"
msgstr "<link=\"BIOCHEMISTRYBIODIESELREFINERY\">Refinería de Biodiésel</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.DESC"
msgid "A device that uses organic oil and bacterial enzymes to print small sheets of lipid derived biopolymers which are compressed in to a solid block."
msgstr "Un dispositivo que utiliza aceite orgánico y enzimas bacterianas para imprimir pequeñas láminas de biopolímeros derivados de lípidos que se comprimen en un bloque sólido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.EFFECT"
msgid ""
"Synthesizes <link=\"BIOPLASTIC\">Bioplastic</link> from <link=\"PHYTOOIL\">Phyto Oil</link> and <link=\"CARBONDIOXIDE\">Carbon Dioxide</link>.\n"
"The enzymes requires a microbial medium in the form of <link=\"MUSHBAR\">Mush Bar</link>."
msgstr ""
"Sintetiza <link=\"BIOPLASTIC\">Bioplástico</link> a partir de <link=\"PHYTOOIL\">Fitoaceite</link> y <link=\"CARBONDIOXIDE\">Dióxido de Carbono</link>.\n"
"Las enzimas requieren un medio microbiano en forma de <link=\"MUSHBAR\">Barra de Masa</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_BIOPLASTICPRINTER.NAME"
msgid "<link=\"BIOCHEMISTRYBIOPLASTICPRINTER\">Bioplastic Printer</link>"
msgstr "<link=\"BIOCHEMISTRYBIOPLASTICPRINTER\">Impresora de Bioplástico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.DESC"
msgid "A mechanical device built to extract oil from raw materials. The raw materials are squeezed under high pressure through a caged barrel-like cavity."
msgstr "Un dispositivo mecánico construido para extraer aceite de materias primas. Las materias primas se exprimen a alta presión a través de una cavidad en forma de barril enjaulado."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.EFFECT"
msgid ""
"Extract <link=\"LIQUIDVEGEOIL\">Vegetable Oil</link> from raw food ingredients. The amount of oil, and the solid waste in the form of <link=\"SOLIDBIOMASS\">Compressed Biomass</link> depend of the ingredient choosen.\n"
"Can be diluted with water to produce <link=\"PHYTOOIL\">Phyto Oil</link>"
msgstr ""
"Extrae <link=\"LIQUIDVEGEOIL\">Aceite Vegetal</link> de ingredientes de comida cruda. La cantidad de aceite y el residuo sólido en forma de <link=\"SOLIDBIOMASS\">Biomasa Comprimida</link> dependen del ingrediente elegido.\n"
"Se puede diluir con agua para producir <link=\"PHYTOOIL\">Fitoaceite</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_EXPELLERPRESS.NAME"
msgid "<link=\"BIOCHEMISTRYEXPELLERPRESS\">Expeller Press</link>"
msgstr "<link=\"BIOCHEMISTRYEXPELLERPRESS\">Prensa Expulsora</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.DESC"
msgid "A simple device capable of producing high-quality phyto oil."
msgstr "Un dispositivo simple capaz de producir fitoaceite de alta calidad."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.EFFECT"
msgid "Produces <link=\"PHYTOOIL\">Phyto Oil</link> by diluting <link=\"LIQUIDVEGEOIL\">Vegetable Oil</link> with <link=\"WATER\">Water</link>."
msgstr "Produce <link=\"PHYTOOIL\">Fitoaceite</link> diluyendo <link=\"LIQUIDVEGEOIL\">Aceite Vegetal</link> con <link=\"WATER\">Agua</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.BIOCHEMISTRY_SYNTHESIZERPHYTOOIL.NAME"
msgid "<link=\"BIOCHEMISTRYSYNTHESIZERPHYTOOIL\">Phyto Oil Mixer</link>"
msgstr "<link=\"BIOCHEMISTRYSYNTHESIZERPHYTOOIL\">Mezclador de Fitoaceite</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.DESC"
msgid "Store solids and other industrial materials at a constant temperature moderation."
msgstr "Almacena sólidos y otros materiales industriales a una moderación de temperatura constante."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.EFFECT"
msgid ""
"Store the <link=\"ELEMENTSSOLID\">Solid Materials</link> of your choosing.\n"
"\n"
"Consumes <link=\"POWER\">Power</link> to cool the contents down to 24°C.\n"
"\n"
"Cannot store any liquefiable solids.\n"
"Takes items from conveyor rails based on its filters."
msgstr ""
"Almacena los <link=\"ELEMENTSSOLID\">Materiales Sólidos</link> de tu elección.\n"
"\n"
"Consume <link=\"POWER\">Energía</link> para enfriar el contenido hasta 24 °C.\n"
"\n"
"No puede almacenar ningún sólido licuable.\n"
"Toma objetos de los rieles transportadores según sus filtros."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETFROZEN.NAME"
msgid "<link=\"CABINETFROZEN\">Refrigerated Storage Cabinet</link>"
msgstr "<link=\"CABINETFROZEN\">Gabinete de Almacenamiento Refrigerado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.DESC"
msgid "Store solids and other industrial materials at a constant temperature moderation."
msgstr "Almacena sólidos y otros materiales industriales a una moderación de temperatura constante."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.EFFECT"
msgid ""
"Store the <link=\"ELEMENTSSOLID\">Solid Materials</link> of your choosing.\n"
"The cabinet prevents temperature exchange with the environment, as well gas leakage.\n"
"Takes items from conveyor rails based on its filters."
msgstr ""
"Almacena los <link=\"ELEMENTSSOLID\">Materiales Sólidos</link> de tu elección.\n"
"El gabinete evita el intercambio de temperatura con el entorno, así como la fuga de gases.\n"
"Toma objetos de los rieles transportadores según sus filtros."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CABINETNORMAL.NAME"
msgid "<link=\"CABINETNORMAL\">Insulated Storage Cabinet</link>"
msgstr "<link=\"CABINETNORMAL\">Gabinete de Almacenamiento Aislado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.DESC"
msgid "Cement is a quite old building material, but still pretty much useful."
msgstr "El cemento es un material de construcción bastante antiguo, pero aún muy útil."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.EFFECT"
msgid "A device that can homogeneously combine several solid and liquid ingredients used in the production of cement."
msgstr "Un dispositivo que puede combinar de manera homogénea varios ingredientes sólidos y líquidos utilizados en la producción de cemento."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CEMENTMIXER.NAME"
msgid "<link=\"CEMENTMIXER\">Cement Mixer</link>"
msgstr "<link=\"CEMENTMIXER\">Mezcladora de Cemento</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.DESC"
msgid "Address a wide range of industrial and chemical applications."
msgstr "Aborda una amplia gama de aplicaciones industriales y químicas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.EFFECT"
msgid ""
"An advanced insulated electrical kiln in which the heat is applied by induction heating of metal.\n"
"The advantage of the induction kiln is a clean, energy-efficient and well-controllable heating process compared to most other means of fuel heating."
msgstr ""
"Un horno eléctrico aislado avanzado en el que el calor se aplica mediante calentamiento por inducción de metal.\n"
"La ventaja del horno de inducción es un proceso de calentamiento limpio, energéticamente eficiente y bien controlable en comparación con la mayoría de los otros medios de calentamiento por combustible."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDKILN.NAME"
msgid "<link=\"CHEMICALADVANCEDKILN\">Advanced Kiln</link>"
msgstr "<link=\"CHEMICALADVANCEDKILN\">Horno Avanzado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.DESC"
msgid "An improved refinery capable of bulk smelting process, as well exclusive metal production."
msgstr "Una refinería mejorada capaz de realizar procesos de fundición a granel, así como producción exclusiva de metales."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.EFFECT"
msgid ""
"An advanced method for production of <link=\"REFINEDMETAL\">Refined Metals</link> from raw <link=\"RAWMETAL\">Metal Ore</link>.\n"
"\n"
"Significantly <link=\"HEAT\">Heats</link> and strongly prefers <link=\"SUPERCOOLANT\">Super Coolant</link> piped into it.\n"
"\n"
"Using other coolants will cause the refinery to operate at reduced speeds.\n"
"\n"
"Duplicants will not fabricate items unless recipes are queued."
msgstr ""
"Un método avanzado para la producción de <link=\"REFINEDMETAL\">Metales Refinados</link> a partir de <link=\"RAWMETAL\">Mineral Metálico</link> crudo.\n"
"\n"
"Genera <link=\"HEAT\">Calor</link> significativamente y prefiere encarecidamente que se le suministre <link=\"SUPERCOOLANT\">Superrefrigerante</link> por tubería.\n"
"\n"
"Usar otros refrigerantes hará que la refinería funcione a velocidades reducidas.\n"
"\n"
"Los Duplicantes no fabricarán objetos a menos que las recetas estén en cola."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_ADVANCEDMETALREFINERY.NAME"
msgid "<link=\"CHEMICALADVANCEDMETALREFINERY\">Advanced Metal Refinery</link>"
msgstr "<link=\"CHEMICALADVANCEDMETALREFINERY\">Refinería de Metal Avanzada</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.DESC"
msgid "A fancy pump capable to detect Chlorine Gas and pump it."
msgstr "Una bomba sofisticada capaz de detectar Gas Cloro y bombearlo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.EFFECT"
msgid "Automatically detects trace of <link=\"CHLORINEGAS\">Chlorine Gas</link> and extract it out of the surroudings."
msgstr "Detecta automáticamente rastros de <link=\"CHLORINEGAS\">Gas Cloro</link> y los extrae de los alrededores."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AIO_CHLORINEPUMP.NAME"
msgid "<link=\"CHEMICALAIOCHLORINEPUMP\">Chlorine Gas Filter</link>"
msgstr "<link=\"CHEMICALAIOCHLORINEPUMP\">Filtro de Gas Cloro</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.DESC"
msgid "An advanced catalytic cracking furnace which the ammonia synthesis reaction is reversed at elevated temperatures."
msgstr "Un horno avanzado de craqueo catalítico en el cual la reacción de síntesis de amoníaco se invierte a temperaturas elevadas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.EFFECT"
msgid ""
"Break down <link=\"AMMONIAGAS\">Ammonia</link> into <link=\"HYDROGEN\">Hydrogen</link> and <link=\"NITROGENGAS\">Nitrogen</link> using <link=\"IRON\">Iron</link> as catalyst. \n"
"The cracking process exudes a lot of heat.\n"
"\n"
"IMPORTANT: The building require all pipes ports to be connected with their respective pipes in order for it to operate."
msgstr ""
"Descompone <link=\"AMMONIAGAS\">Amoníaco</link> en <link=\"HYDROGEN\">Hidrógeno</link> y <link=\"NITROGENGAS\">Gas Nitrógeno</link> utilizando <link=\"IRON\">Hierro</link> como catalizador. \n"
"El proceso de craqueo exuda mucho calor.\n"
"\n"
"IMPORTANTE: El edificio requiere que todos los puertos de tuberías estén conectados con sus respectivas tuberías para poder operar."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIABREAKER.NAME"
msgid "<link=\"CHEMICALAMMONIABREAKER\">Ammonia Breaker</link>"
msgstr "<link=\"CHEMICALAMMONIABREAKER\">Separador de Amoníaco</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.DESC"
msgid "An industrial grade rotatory compressor unit that criticaly increase the pressure of a gas by reducing its volume, while cooling it down until liquid state is reached."
msgstr "Una unidad de compresor rotativo de grado industrial que aumenta críticamente la presión de un gas reduciendo su volumen, mientras lo enfría hasta alcanzar el estado líquido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.EFFECT"
msgid "Compresses Ammonia gas and cool it down to liquid Ammonia. This device is also capable of storing liquid with complete insulation."
msgstr "Comprime gas Amoníaco y lo enfría hasta convertirlo en Amoníaco líquido. Este dispositivo también es capaz de almacenar líquido con aislamiento completo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_AMMONIACOMPRESSOR.NAME"
msgid "<link=\"CHEMICALAMMONIACOMPRESSOR\">Ammonia Compressor</link>"
msgstr "<link=\"CHEMICALAMMONIACOMPRESSOR\">Compresor de Amoníaco</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.DESC"
msgid "A large sized industrial mill that crushes raw ores using steel balls and special mixture of acids. It is capable to process much more than the standard mill, as well as more efficient in the extraction of valuable minerals from the raw ore sludge."
msgstr "Un molino industrial de gran tamaño que tritura minerales crudos utilizando bolas de acero y una mezcla especial de ácidos. Es capaz de procesar mucho más que el molino estándar, además de ser más eficiente en la extracción de minerales valiosos del lodo de mineral crudo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.EFFECT"
msgid "Crush down <link=\"BUILDABLERAW\">Raw Minerals</link> in to useful materials and industrial ingredients."
msgstr "Tritura <link=\"BUILDABLERAW\">Minerales Crudos</link> en materiales útiles e ingredientes industriales."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_BALLCRUSHERMILL.NAME"
msgid "<link=\"CHEMICALBALLCRUSHERMILL\">Ball Crusher Mill (Chemical Washing)</link>"
msgstr "<link=\"CHEMICALBALLCRUSHERMILL\">Molino Triturador de Bolas (Lavado Químico)</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.DESC"
msgid "An industrial grade rotatory compressor unit that criticaly increase the pressure of a gas by reducing its volume, while cooling it down until liquid state is reached."
msgstr "Una unidad de compresor rotativo de grado industrial que aumenta críticamente la presión de un gas reduciendo su volumen, mientras lo enfría hasta alcanzar el estado líquido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.EFFECT"
msgid "Compresses <link=\"CARBONDIOXIDE\">Carbon Dioxide</link> gas and cool it down to<link=\"LIQUIDCARBONDIOXIDE\">Liquid Carbon Dioxide</link>. This device is also capable of storing liquid with complete insulation."
msgstr "Comprime gas <link=\"CARBONDIOXIDE\">Dióxido de Carbono</link> y lo enfría hasta obtener <link=\"LIQUIDCARBONDIOXIDE\">Dióxido de Carbono Líquido</link>. Este dispositivo también es capaz de almacenar líquido con aislamiento completo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CARBONDIOXIDECOMPRESSOR.NAME"
msgid "<link=\"CHEMICALCARBONDIOXIDECOMPRESSOR\">Carbon Dioxide Compressor</link>"
msgstr "<link=\"CHEMICALCARBONDIOXIDECOMPRESSOR\">Compresor de Dióxido de Carbono</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.DESC"
msgid "A fancy pump capable to detect Carbon Dioxide and pump it."
msgstr "Una bomba sofisticada capaz de detectar Dióxido de Carbono y bombearlo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.EFFECT"
msgid "Automatically detects trace of <link=\"CARBONDIOXIDE\">Carbon Dioxide</link> and extract it out of the surroudings."
msgstr "Detecta automáticamente rastros de <link=\"CARBONDIOXIDE\">Dióxido de Carbono</link> y los extrae de los alrededores."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2PUMP.NAME"
msgid "<link=\"CHEMICALCO2PUMP\">CO2 Filter</link>"
msgstr "<link=\"CHEMICALCO2PUMP\">Filtro de CO2</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.BASEGAME_RECIPE
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.BASEGAME_RECIPE"
msgid ""
"Sabatier Reaction: \n"
" <link=\"LIQUIDCARBONDIOXIDE\">Liquid Carbon Dioxide</link>, <link=\"HYDROGEN\">Hydrogen</link> and <link=\"IRON\">Iron</link> as catalyst. The Sabatier Reaction produce <link=\"WATER\">Water</link>, <link=\"METHANE\">Natural Gas</link> and <link=\"RUST\">Rust</link> as waste product.\n"
"\n"
"Bosch Reaction: \n"
"<link=\"CARBONDIOXIDE\">Carbon Dioxide</link>, <link=\"HYDROGEN\">Hydrogen</link> and <link=\"IRON\">Iron</link> as catalyst. The Bosch Reaction produce <link=\"STEAM\">Steam</link>, <link=\"FULLERENE\">Fullerene</link> and <link=\"RUST\">Rust</link> as waste product."
msgstr ""
"Reacción de Sabatier: \n"
" <link=\"LIQUIDCARBONDIOXIDE\">Dióxido de Carbono Líquido</link>, <link=\"HYDROGEN\">Hidrógeno</link> y <link=\"IRON\">Hierro</link> como catalizador. La Reacción de Sabatier produce <link=\"WATER\">Agua</link>, <link=\"METHANE\">Gas Natural</link> y <link=\"RUST\">Óxido</link> como producto de desecho.\n"
"\n"
"Reacción de Bosch: \n"
"<link=\"CARBONDIOXIDE\">Dióxido de Carbono</link>, <link=\"HYDROGEN\">Hidrógeno</link> y <link=\"IRON\">Hierro</link> como catalizador. La Reacción de Bosch produce <link=\"STEAM\">Vapor</link>, <link=\"FULLERENE\">Fulereno</link> y <link=\"RUST\">Óxido</link> como producto de desecho."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.DESC"
msgid "An autonomous chemical device capable of executing both Bosch and Sabatier Reactions based on the input conditions."
msgstr "Un dispositivo químico autónomo capaz de ejecutar tanto las Reacciones de Bosch como las de Sabatier según las condiciones de entrada."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_CO2RECYCLER.EFFECT"
