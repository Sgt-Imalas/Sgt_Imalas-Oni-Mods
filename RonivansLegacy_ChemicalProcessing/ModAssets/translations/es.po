msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMIGNEOUSROCKTILE.DESC"
msgid "A notable tile made exclusively with Igneous Rock."
msgstr "Una baldosa notable hecha exclusivamente con Roca Ígnea."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMIGNEOUSROCKTILE.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CUSTOMIGNEOUSROCKTILE.EFFECT"
msgid "Igneous tiles enhance not only the environmental beauty, but also increases duplicants walking speed."
msgstr "Las baldosas ígneas no solo mejoran la belleza ambiental, sino que también aumentan la velocidad de caminata de los duplicantes."

