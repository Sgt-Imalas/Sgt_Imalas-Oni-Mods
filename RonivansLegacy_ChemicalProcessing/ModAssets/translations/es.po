#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SMALLLIQUIDRESERVOIR.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SMALLLIQUIDRESERVOIR.DESC"
msgid "A small sized reservoir. This variant has top to bottom flow"
msgstr "Un depósito de tamaño pequeño. Esta variante tiene un flujo de arriba hacia abajo"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SMALLLIQUIDRESERVOIR.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SMALLLIQUIDRESERVOIR.EFFECT"
