msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_RED.DESC"
msgid "A red variant of the Household Fridge"
msgstr "Una variante roja del Refrigerador Doméstico"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_FRIDGELARGE.FACADES.FRIDGELARGE_RED.NAME
