msgstr "Una fisura caliente altamente presurizada que entra en erupción periódicamente con <link=\"LIQUIDPHOSPHORUS\">Fósforo Líquido</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.PHOSPHORUSGEYSER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.PHOSPHORUSGEYSER.NAME"
msgid "<link=\"GEYSERGENERICPHOSPHORUSGEYSER\">Liquid Phosphorus Geyser</link>"
msgstr "<link=\"GEYSERGENERICPHOSPHORUSGEYSER\">Géiser de Fósforo Líquido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.RAWGASVENT.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.RAWGASVENT.DESC"
msgid "A highly pressurized geothermal vent that periodically erupts with hot <link=\"RAWNATURALGAS\">Raw Natural Gas</link>."
msgstr "Un respiradero geotérmico altamente presurizado que entra en erupción periódicamente con <link=\"RAWNATURALGAS\">Gas Natural Crudo</link> caliente."

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.RAWGASVENT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.RAWGASVENT.NAME"
msgid "<link=\"GEYSERGENERICRAWGASVENT\">Hot Raw Natural Gas Vent</link>"
msgstr "<link=\"GEYSERGENERICRAWGASVENT\">Respiradero de Gas Natural Crudo Caliente</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.SOURWATERGEYSER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.SOURWATERGEYSER.DESC"
msgid "A highly pressurized geyser that periodically erupts with cold <link=\"SOURWATER\">Sour Water</link>."
msgstr "Un géiser altamente presurizado que entra en erupción periódicamente con <link=\"SOURWATER\">Agua Agria</link> fría."

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.SOURWATERGEYSER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.SOURWATERGEYSER.NAME"
msgid "<link=\"GEYSERGENERICSOURWATERGEYSER\">Sour Water Geyser</link>"
msgstr "<link=\"GEYSERGENERICSOURWATERGEYSER\">Géiser de Agua Agria</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NAME"
msgid "Acid Burns"
msgstr "Quemaduras por Ácido"

#. RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NOTIFICATION_NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NOTIFICATION_NAME"
msgid "Chemical Burns"
msgstr "Quemaduras Químicas"

#. RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NOTIFICATION_TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.NOTIFICATION_TOOLTIP"
msgid "Duplicants have been exposed to acids."
msgstr "Los duplicantes han sido expuestos a ácidos."

#. RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.DUPLICANTS.STATUSITEMS.ACIDBURNS.TOOLTIP"
msgid "This duplicant has been injured from their recent exposure to corrosive acids."
msgstr "Este duplicante ha resultado herido por su reciente exposición a ácidos corrosivos."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMITEORE_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMITEORE_SOLID.DESC"
msgid "Chromite is a crystalline mineral composed primarily of <link=\"IRON\">Iron</link> and <link=\"AIOCHROMIUMSOLID\">Chromium</link> compounds."
msgstr "La cromita es un mineral cristalino compuesto principalmente por compuestos de <link=\"IRON\">Hierro</link> y <link=\"AIOCHROMIUMSOLID\">Cromo</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMITEORE_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMITEORE_SOLID.NAME"
msgid "<link=\"AIOCHROMITEORESOLID\">Chromite</link>"
msgstr "<link=\"AIOCHROMITEORESOLID\">Cromita</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_GAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_GAS.DESC"
msgid "(Cr) Chromium is a steely-grey, lustrous, hard and brittle transition metal in its gaseous state."
msgstr "(Cr) El cromo es un metal de transición de color gris acero, brillante, duro y quebradizo en su estado gaseoso."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_GAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_GAS.NAME"
msgid "<link=\"AIOCHROMIUMGAS\">Chromium Gas</link>"
msgstr "<link=\"AIOCHROMIUMGAS\">Gas de Cromo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_LIQUID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_LIQUID.DESC"
msgid "(Cr) Chromium is a steely-grey, lustrous, hard and brittle transition metal in its molten state."
msgstr "(Cr) El cromo es un metal de transición de color gris acero, brillante, duro y quebradizo en su estado fundido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_LIQUID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_LIQUID.NAME"
msgid "<link=\"AIOCHROMIUMLIQUID\">Molten Chromium</link>"
msgstr "<link=\"AIOCHROMIUMLIQUID\">Cromo Fundido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_SOLID.DESC"
msgid "(Cr) Chromium is a steely-grey, lustrous, hard and brittle transition metal."
msgstr "(Cr) El cromo es un metal de transición de color gris acero, brillante, duro y quebradizo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_CHROMIUM_SOLID.NAME"
msgid "<link=\"AIOCHROMIUMSOLID\">Chromium</link>"
msgstr "<link=\"AIOCHROMIUMSOLID\">Cromo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_LIQUID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_LIQUID.DESC"
msgid "Ferrochrome is an alloy of <link=\"IRON\">Iron</link> and <link=\"AIOCHROMIUMSOLID\">Chromium</link>, used in the production of stainless steel and other alloys, currently in its molten state."
msgstr "El ferrocromo es una aleación de <link=\"IRON\">Hierro</link> y <link=\"AIOCHROMIUMSOLID\">Cromo</link>, utilizada en la producción de acero inoxidable y otras aleaciones, actualmente en su estado fundido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_LIQUID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_LIQUID.NAME"
msgid "<link=\"AIOFERROCHROMELIQUID\">Molten Ferrochrome</link>"
msgstr "<link=\"AIOFERROCHROMELIQUID\">Ferrocromo Fundido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_SOLID.DESC"
msgid "Ferrochrome is an alloy of <link=\"IRON\">Iron</link> and <link=\"AIOCHROMIUMSOLID\">Chromium</link>, used in the production of stainless steel and other alloys."
msgstr "El ferrocromo es una aleación de <link=\"IRON\">Hierro</link> y <link=\"AIOCHROMIUMSOLID\">Cromo</link>, utilizada en la producción de acero inoxidable y otras aleaciones."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_FERROCHROME_SOLID.NAME"
msgid "<link=\"AIOFERROCHROMESOLID\">Ferrochrome</link>"
msgstr "<link=\"AIOFERROCHROMESOLID\">Ferrocromo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_INVAR_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_INVAR_SOLID.DESC"
msgid "Invar is a nickel-iron alloy, composed of 35% <link=\"NICKEL\">Nickel</link> and 65% <link=\"IRON\">Iron</link> which is notable for its uniquely low coefficient of thermal expansion."
msgstr "El invar es una aleación de níquel-hierro, compuesta de 35% <link=\"NICKEL\">Níquel</link> y 65% <link=\"IRON\">Hierro</link> que es notable por su coeficiente de expansión térmica singularmente bajo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_INVAR_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_INVAR_SOLID.NAME"
msgid "<link=\"AIOINVARSOLID\">Invar</link>"
msgstr "<link=\"AIOINVARSOLID\">Invar</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_PERMENDUR_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_PERMENDUR_SOLID.DESC"
msgid ""
"Permendur is a cobalt-iron soft ferromagnetic alloy with equal parts of <link=\"COBALT\">Cobalt</link> and <link=\"IRON\">Iron</link> which is notable for its high magnetic saturation level.\n"
"Heat treatment gives this material a high structural stability."
msgstr ""
"El permendur es una aleación ferromagnética blanda de cobalto-hierro con partes iguales de <link=\"COBALT\">Cobalto</link> y <link=\"IRON\">Hierro</link> que es notable por su alto nivel de saturación magnética.\n"
"El tratamiento térmico le da a este material una alta estabilidad estructural."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_PERMENDUR_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_PERMENDUR_SOLID.NAME"
msgid "<link=\"AIOPERMENDURSOLID\">Permendur</link>"
msgstr "<link=\"AIOPERMENDURSOLID\">Permendur</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_STAINLESSSTEEL_SOLID.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_STAINLESSSTEEL_SOLID.DESC"
msgid "Stainless Steel is an <link=\"IRON\">Iron</link> based alloy that contains <link=\"AIOCHROMIUMSOLID\">Chromium</link>, making it highly resistant to rust and corrosion."
msgstr "El Acero Inoxidable es una aleación a base de <link=\"IRON\">Hierro</link> que contiene <link=\"AIOCHROMIUMSOLID\">Cromo</link>, lo que la hace altamente resistente al óxido y la corrosión."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_STAINLESSSTEEL_SOLID.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AIO_STAINLESSSTEEL_SOLID.NAME"
msgid "<link=\"AIOSTAINLESSSTEELSOLID\">Stainless Steel</link>"
msgstr "<link=\"AIOSTAINLESSSTEELSOLID\">Acero Inoxidable</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIAGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIAGAS.DESC"
msgid "(NH<sub>3</sub>) Ammonia is an inorganic compound of nitrogen and hydrogen. A stable binary hydride, and the simplest pnictogen hydride, ammonia is a gas with a distinct pungent smell."
msgstr "(NH<sub>3</sub>) El amoníaco es un compuesto inorgánico de nitrógeno e hidrógeno. Un hidruro binario estable, y el hidruro de pnictógeno más simple, el amoníaco es un gas con un olor acre distintivo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIAGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIAGAS.NAME"
msgid "<link=\"AMMONIAGAS\">Ammonia</link>"
msgstr "<link=\"AMMONIAGAS\">Amoníaco</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMSALT.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMSALT.DESC"
msgid "(NH<sub>4</sub>NO<sub>3</sub>) Nodules of dirt containing high concentrations of Ammonium Nitrate."
msgstr "(NH<sub>4</sub>NO<sub>3</sub>) Nódulos de tierra que contienen altas concentraciones de Nitrato de Amonio."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMSALT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMSALT.NAME"
msgid "<link=\"AMMONIUMSALT\">Nitrate Nodules</link>"
msgstr "<link=\"AMMONIUMSALT\">Nódulos de Nitrato</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMWATER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMWATER.DESC"
msgid "(NH<sub>4</sub>OH) Ammonium hydroxide is a solution of <link=\"AMMONIAGAS\">Ammonia</link> and <link=\"WATER\">Water</link>."
msgstr "(NH<sub>4</sub>OH) El hidróxido de amonio es una solución de <link=\"AMMONIAGAS\">Amoníaco</link> y <link=\"WATER\">Agua</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMWATER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AMMONIUMWATER.NAME"
msgid "<link=\"AMMONIUMWATER\">Ammonium Water</link>"
msgstr "<link=\"AMMONIUMWATER\">Agua Amoniacal</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ARGENTITEORE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ARGENTITEORE.DESC"
msgid "(Ag<sub>2</sub>S) Argentite is a cubic silver sulfide is a conductive metal, and the main source of refined <link=\"SOLIDSILVER\">Silver</link> metal."
msgstr "(Ag<sub>2</sub>S) La argentita es un sulfuro de plata cúbico es un metal conductor, y la principal fuente de metal de <link=\"SOLIDSILVER\">Plata</link> refinado."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ARGENTITEORE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ARGENTITEORE.NAME"
msgid "<link=\"ARGENTITEORE\">Silver Ore</link>"
msgstr "<link=\"ARGENTITEORE\">Mineral de Plata</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AURICHALCITEORE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AURICHALCITEORE.DESC"
msgid "((Zn,Cu)<sub>5</sub>(CO<sub>3</sub>)<sub>2</sub>(OH)<sub>6</sub>) Aurichalcite is a carbonate mineral, and the main source of refined <link=\"SOLIDZINC\">Zinc</link> metal."
msgstr "((Zn,Cu)<sub>5</sub>(CO<sub>3</sub>)<sub>2</sub>(OH)<sub>6</sub>) La auricalcita es un mineral carbonatado, y la principal fuente de metal de <link=\"SOLIDZINC\">Zinc</link> refinado."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AURICHALCITEORE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.AURICHALCITEORE.NAME"
msgid "<link=\"AURICHALCITEORE\">Zinc Ore</link>"
msgstr "<link=\"AURICHALCITEORE\">Mineral de Zinc</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BASEGRADESAND.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BASEGRADESAND.DESC"
msgid "A heavy sandy material composed mostly of common metallic grains, mixed with other finer mineral particles."
msgstr "Un material arenoso pesado compuesto en su mayoría por granos metálicos comunes, mezclado con otras partículas minerales más finas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BASEGRADESAND.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BASEGRADESAND.NAME"
msgid "<link=\"BASEGRADESAND\">Base-Grade Metallic Sand</link>"
msgstr "<link=\"BASEGRADESAND\">Arena Metálica de Grado Básico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BIOPLASTIC.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BIOPLASTIC.DESC"
msgid "A synthetic biopolymer produced from renewable biomass sources, such as vegetable fats and oils, and enzymes from bacterial biosynthesis. Unlike traditional plastics, which are derived from fossil fuels, bioplastics are obtained from renewable resources."
msgstr "Un biopolímero sintético producido a partir de fuentes de biomasa renovables, como grasas y aceites vegetales, y enzimas de biosíntesis bacteriana. A diferencia de los plásticos tradicionales, que se derivan de combustibles fósiles, los bioplásticos se obtienen de recursos renovables."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BIOPLASTIC.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.BIOPLASTIC.NAME"
msgid "<link=\"BIOPLASTIC\">Bioplastic</link>"
msgstr "<link=\"BIOPLASTIC\">Bioplástico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CARBONFIBER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CARBONFIBER.DESC"
msgid "Carbon fiber-reinforced polymers blocks are extremely strong and light fiber-reinforced plastics that contain carbon fibers. Used on wherever high strength-to-weight ratio and stiffness (rigidity) are required, such as aerospace. Its composition of allotropes of carbon make it extremely resistant to heat."
msgstr ""
"Los bloques de polímeros reforzados con fibra de carbono son plásticos reforzados con fibra extremadamente fuertes y ligeros que contienen fibras de carbono. Se utilizan en cualquier lugar donde se requiera una alta relación resistencia-peso y rigidez, como en la industria aeroespacial. Su composición de alótropos "
"de carbono lo hace extremadamente resistente al calor."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CARBONFIBER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CARBONFIBER.NAME"
msgid "<link=\"CARBONFIBER\">Carbon Composite</link>"
msgstr "<link=\"CARBONFIBER\">Compuesto de Carbono</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CHLOROSCHIST.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CHLOROSCHIST.DESC"
msgid "A dense medium-grained metamorphic rock showing pronounced schistosity. This sample has a high content of chloride minerals within its compacted layers."
msgstr "Una roca metamórfica densa de grano medio que muestra una pronunciada esquistosidad. Esta muestra tiene un alto contenido de minerales de cloruro dentro de sus capas compactadas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CHLOROSCHIST.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CHLOROSCHIST.NAME"
msgid "<link=\"CHLOROSCHIST\">Chloroschist</link>"
msgstr "<link=\"CHLOROSCHIST\">Cloroesquisto</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CONCRETEBLOCK.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CONCRETEBLOCK.DESC"
msgid "Concrete blocks are standard-size rectangular blocks used in building construction. A versatile component made from different aggregates that are often considered waste products."
msgstr "Los bloques de hormigón son bloques rectangulares de tamaño estándar utilizados en la construcción de edificios. Un componente versátil fabricado a partir de diferentes agregados que a menudo se consideran productos de desecho."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CONCRETEBLOCK.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.CONCRETEBLOCK.NAME"
msgid "<link=\"CONCRETEBLOCK\">Concrete Block</link>"
msgstr "<link=\"CONCRETEBLOCK\">Bloque de Hormigón</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.GALENA.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.GALENA.DESC"
msgid "Galena is the natural mineral form of lead(II) sulfide (PbS).It is the most important ore of <link=\"LEAD\">Lead</link> and an important source of <link=\"SOLIDSILVER\">Silver</link>."
msgstr "La galena es la forma mineral natural del sulfuro de plomo(II) (PbS). Es el mineral más importante de <link=\"LEAD\">Plomo</link> y una importante fuente de <link=\"SOLIDSILVER\">Plata</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.GALENA.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.GALENA.NAME"
msgid "<link=\"GALENA\">Galena</link>"
msgstr "<link=\"GALENA\">Galena</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.HIGHGRADESAND.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.HIGHGRADESAND.DESC"
msgid "A glimmering sandy material composed mostly of high quality metallic grains, mixed with other finer mineral particles."
msgstr "Un material arenoso brillante compuesto en su mayoría por granos metálicos de alta calidad, mezclado con otras partículas minerales más finas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.HIGHGRADESAND.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.HIGHGRADESAND.NAME"
msgid "<link=\"HIGHGRADESAND\">High-Grade Metallic Sand</link>"
msgstr "<link=\"HIGHGRADESAND\">Arena Metálica de Alto Grado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ISOPROPANEGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ISOPROPANEGAS.DESC"
msgid "(C(CH<sub>4</sub>)<sub>2</sub>) Isopropane is a petrochemical refrigerant gas suitable for a variety of purposes. Degrades to <link=\"PROPANE\">Propane</link> at higher temperatures."
msgstr "(C(CH<sub>4</sub>)<sub>2</sub>) El isopropano es un gas refrigerante petroquímico adecuado para una variedad de propósitos. Se degrada a <link=\"PROPANE\">Propano</link> a temperaturas más altas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ISOPROPANEGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ISOPROPANEGAS.NAME"
msgid "<link=\"ISOPROPANEGAS\">Isopropane</link>"
msgstr "<link=\"ISOPROPANEGAS\">Isopropano</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDAMMONIA.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDAMMONIA.DESC"
msgid "(NH<sub>3</sub>) Ammonia is an inorganic compound of nitrogen and hydrogen, currently in its cold, liquid state."
msgstr "(NH<sub>3</sub>) El amoníaco es un compuesto inorgánico de nitrógeno e hidrógeno, actualmente en su estado líquido y frío."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDAMMONIA.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDAMMONIA.NAME"
msgid "<link=\"LIQUIDAMMONIA\">Liquid Ammonia</link>"
msgstr "<link=\"LIQUIDAMMONIA\">Amoníaco Líquido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDBIODIESEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDBIODIESEL.DESC"
msgid "Renewable diesel is a renewable biofuel from biological sources like vegetable oils. Used as an alternative to fossil fuels."
msgstr "El diésel renovable es un biocombustible renovable de fuentes biológicas como los aceites vegetales. Se utiliza como alternativa a los combustibles fósiles."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDBIODIESEL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDBIODIESEL.NAME"
msgid "<link=\"LIQUIDBIODIESEL\">Renewable Diesel</link>"
msgstr "<link=\"LIQUIDBIODIESEL\">Diésel Renovable</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITRIC.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITRIC.DESC"
msgid "(HNO<sub>3</sub>) An inorganic mineral acid composed of the elements nitrogen, oxygen and hydrogen. Presented in its liquid state, is the primary reagent used for nitration – the addition of a nitro group, typically to an organic molecule."
msgstr "(HNO<sub>3</sub>) Un ácido mineral inorgánico compuesto por los elementos nitrógeno, oxígeno e hidrógeno. Presentado en su estado líquido, es el reactivo principal utilizado para la nitración: la adición de un grupo nitro, típicamente a una molécula orgánica."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITRIC.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITRIC.NAME"
msgid "<link=\"LIQUIDNITRIC\">Nitric Acid</link>"
msgstr "<link=\"LIQUIDNITRIC\">Ácido Nítrico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITROGEN.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITROGEN.DESC"
msgid "(N<sub>2</sub>) Nitrogen is a nonmetal and the lightest member of group 15 of the periodic table, currently in its cold, liquid state."
msgstr "(N<sub>2</sub>) El nitrógeno es un no metal y el miembro más ligero del grupo 15 de la tabla periódica, actualmente en su estado líquido y frío."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITROGEN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDNITROGEN.NAME"
msgid "<link=\"LIQUIDNITROGEN\">Liquid Nitrogen</link>"
msgstr "<link=\"LIQUIDNITROGEN\">Nitrógeno Líquido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDSULFURIC.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDSULFURIC.DESC"
msgid "(H<sub>2</sub>SO<sub>4</sub>) A mineral acid composed of the elements sulfur, oxygen and hydrogen. Presented in its liquid state, it is a very dangerous chemical for its corrosive nature."
msgstr "(H<sub>2</sub>SO<sub>4</sub>) Un ácido mineral compuesto por los elementos azufre, oxígeno e hidrógeno. Presentado en su estado líquido, es un producto químico muy peligroso por su naturaleza corrosiva."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDSULFURIC.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDSULFURIC.NAME"
msgid "<link=\"LIQUIDSULFURIC\">Sulfuric Acid</link>"
msgstr "<link=\"LIQUIDSULFURIC\">Ácido Sulfúrico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDVEGEOIL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDVEGEOIL.DESC"
msgid "Liquid oil extracted from vegetable biomass, composed of triglycerides and monounsaturated fatty acids."
msgstr "Aceite líquido extraído de biomasa vegetal, compuesto por triglicéridos y ácidos grasos monoinsaturados."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDVEGEOIL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LIQUIDVEGEOIL.NAME"
msgid "<link=\"LIQUIDVEGEOIL\">Vegetable Oil</link>"
msgstr "<link=\"LIQUIDVEGEOIL\">Aceite Vegetal</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LOWGRADESAND.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LOWGRADESAND.DESC"
msgid "A sandy material composed mostly of low quality metallic grains, mixed with other finer mineral particles."
msgstr "Un material arenoso compuesto en su mayoría por granos metálicos de baja calidad, mezclado con otras partículas minerales más finas."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LOWGRADESAND.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.LOWGRADESAND.NAME"
msgid "<link=\"LOWGRADESAND\">Low-Grade Metallic Sand</link>"
msgstr "<link=\"LOWGRADESAND\">Arena Metálica de Bajo Grado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.METEORORE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.METEORORE.DESC"
msgid "A dense stony mass formed when various types of dust and small grains in the early Solar System accreted to form primitive asteroids. Despite their stony nature, these collision remnants contain traces of rare metals."
msgstr "Una densa masa pedregosa formada cuando varios tipos de polvo y pequeños granos en el Sistema Solar primitivo se acumularon para formar asteroides primitivos. A pesar de su naturaleza pedregosa, estos restos de colisiones contienen trazas de metales raros."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.METEORORE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.METEORORE.NAME"
msgid "<link=\"METEORORE\">Meteor Ore</link>"
msgstr "<link=\"METEORORE\">Mineral de Meteorito</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSILVER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSILVER.DESC"
msgid "(Ag) Silver is soft, white, lustrous transition metal, in its molten state."
msgstr "(Ag) La plata es un metal de transición suave, blanco y brillante, en su estado fundido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSILVER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSILVER.NAME"
msgid "<link=\"MOLTENSILVER\">Molten Silver</link>"
msgstr "<link=\"MOLTENSILVER\">Plata Fundida</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSLAG.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSLAG.DESC"
msgid "Molten Slag is a by-product of smelting (pyrometallurgical) ores and used metals. Present in molten state, this waste materail needs to be cooled down to solid <link=\"SOLIDSLAG\">Slag</link> before can be used."
msgstr "La Escoria Fundida es un subproducto de la fundición (pirometalúrgica) de minerales y metales usados. Presente en estado fundido, este material de desecho debe enfriarse hasta convertirse en <link=\"SOLIDSLAG\">Escoria</link> sólida antes de poder utilizarse."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSLAG.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENSLAG.NAME"
msgid "<link=\"MOLTENSLAG\">Molten Slag</link>"
msgstr "<link=\"MOLTENSLAG\">Escoria Fundida</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENZINC.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENZINC.DESC"
msgid "(Zn) Zinc is a bluish-white, lustrous, diamagnetic metal in its molten state."
msgstr "(Zn) El zinc es un metal diamagnético, brillante, de color blanco azulado en su estado fundido."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENZINC.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.MOLTENZINC.NAME"
msgid "<link=\"MOLTENZINC\">Molten Zinc</link>"
msgstr "<link=\"MOLTENZINC\">Zinc Fundido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.NITROGENGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.NITROGENGAS.DESC"
msgid "(N<sub>2</sub>) Nitrogen is a nonmetal and the lightest member of group 15 of the periodic table."
msgstr "(N<sub>2</sub>) El nitrógeno es un no metal y el miembro más ligero del grupo 15 de la tabla periódica."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.NITROGENGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.NITROGENGAS.NAME"
msgid "<link=\"NITROGENGAS\">Nitrogen</link>"
msgstr "<link=\"NITROGENGAS\">Nitrógeno</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PHOSPHORBRONZE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PHOSPHORBRONZE.DESC"
msgid "An alloy composed of <link=\"COPPER\">Copper</link>, <link=\"LEAD\">Lead</link> and <link=\"PHOSPHORUS\">Phosphorus</link>. Among copper based alloys it is remarkable tough, and has a relative low thermal conductivity."
msgstr "Una aleación compuesta de <link=\"COPPER\">Cobre</link>, <link=\"LEAD\">Plomo</link> y <link=\"PHOSPHORUS\">Fósforo</link>. Entre las aleaciones a base de cobre es notablemente tenaz y tiene una conductividad térmica relativamente baja."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PHOSPHORBRONZE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PHOSPHORBRONZE.NAME"
msgid "<link=\"PHOSPHORBRONZE\">Phosphor Bronze</link>"
msgstr "<link=\"PHOSPHORBRONZE\">Bronce Fosforado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PLASTEEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PLASTEEL.DESC"
msgid "A composite of <link=\"POLYPROPYLENE\">Plastic</link> stabilized fibers grown into a <link=\"STEEL\">Steel</link> crystal structure. It is much more stronger and lighter than standard metals alloys, and has a very low thermal conductivity."
msgstr "Un compuesto de fibras estabilizadas de <link=\"POLYPROPYLENE\">Plástico</link> cultivadas en una estructura cristalina de <link=\"STEEL\">Acero</link>. Es mucho más fuerte y liviano que las aleaciones metálicas estándar, y tiene una conductividad térmica muy baja."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PLASTEEL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.PLASTEEL.NAME"
msgid "<link=\"PLASTEEL\">Plasteel</link>"
msgstr "<link=\"PLASTEEL\">Plastiacero</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.RAWNATURALGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.RAWNATURALGAS.DESC"
msgid "A fossil gas consisting of gaseous hydrocarbons and other impurites. The majority of the gas mass is composed of <link=\"METHANE\">Methane</link>, <link=\"PROPANE\">Propane</link> and <link=\"SOURGAS\">Sour Gas</link>."
msgstr "Un gas fósil que consiste en hidrocarburos gaseosos y otras impurezas. La mayor parte de la masa de gas está compuesta por <link=\"METHANE\">Metano</link>, <link=\"PROPANE\">Propano</link> y <link=\"SOURGAS\">Gas Agrio</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.RAWNATURALGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.RAWNATURALGAS.NAME"
msgid "<link=\"RAWNATURALGAS\">Raw Natural Gas</link>"
msgstr "<link=\"RAWNATURALGAS\">Gas Natural Crudo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SILVERGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SILVERGAS.DESC"
msgid "(Ag) Silver is soft, white, lustrous transition metal, in its gaseous state."
msgstr "(Ag) La plata es un metal de transición suave, blanco y brillante, en su estado gaseoso."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SILVERGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SILVERGAS.NAME"
msgid "<link=\"SILVERGAS\">Silver Gas</link>"
msgstr "<link=\"SILVERGAS\">Gas de Plata</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDAMMONIA.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDAMMONIA.DESC"
msgid "(NH<sub>3</sub>) Ammonia is an inorganic compound of nitrogen and hydrogen, currently its its cold, solid state."
msgstr "(NH<sub>3</sub>) El amoníaco es un compuesto inorgánico de nitrógeno e hidrógeno, actualmente en su estado sólido y frío."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDAMMONIA.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDAMMONIA.NAME"
msgid "<link=\"SOLIDAMMONIA\">Ammonia Snow</link>"
msgstr "<link=\"SOLIDAMMONIA\">Nieve de Amoníaco</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIODIESEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIODIESEL.DESC"
msgid "Biodiesel is a renewable biofuel from biological sources like vegetable oils. Frozen solid on its present form."
msgstr "El biodiésel es un biocombustible renovable de fuentes biológicas como los aceites vegetales. Congelado sólido en su forma actual."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIODIESEL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIODIESEL.NAME"
msgid "<link=\"SOLIDBIODIESEL\">Frozen Renewable Diesel</link>"
msgstr "<link=\"SOLIDBIODIESEL\">Diésel Renovable Congelado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIOMASS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIOMASS.DESC"
msgid "A dried, hard pressed clump of organic mass from vegetable origin. Has almost no moisture and can be used as burnable fuel or can be turned to dirt through composting."
msgstr "Un grupo seco y prensado de masa orgánica de origen vegetal. Casi no tiene humedad y se puede utilizar como combustible quemable o se puede convertir en tierra mediante compostaje."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIOMASS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBIOMASS.NAME"
msgid "<link=\"SOLIDBIOMASS\">Compressed Biomass</link>"
msgstr "<link=\"SOLIDBIOMASS\">Biomasa Comprimida</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBORAX.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBORAX.DESC"
msgid "Borax, also known as sodium borate, is an important boron compound, mainly used in the manufacture of <link=\"SOLIDFIBERGLASS\">Fiberglass</link>, and as a flux in metallurgy."
msgstr "El bórax, también conocido como borato de sodio, es un importante compuesto de boro, utilizado principalmente en la fabricación de <link=\"SOLIDFIBERGLASS\">Fibra de Vidrio</link>, y como fundente en la metalurgia."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBORAX.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBORAX.NAME"
msgid "<link=\"SOLIDBORAX\">Borax</link>"
msgstr "<link=\"SOLIDBORAX\">Bórax</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBRASS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBRASS.DESC"
msgid "Brass is an alloy of <link=\"COPPER\">Copper</link> and <link=\"SOLIDZINC\">Zinc</link>, widely used to make utensils due to properties such as having a low melting point, high workability, durability, and electrical and thermal conductivity."
msgstr "El latón es una aleación de <link=\"COPPER\">Cobre</link> y <link=\"SOLIDZINC\">Zinc</link>, ampliamente utilizada para hacer utensilios debido a propiedades como tener un bajo punto de fusión, alta trabajabilidad, durabilidad y conductividad eléctrica y térmica."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBRASS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDBRASS.NAME"
msgid "<link=\"SOLIDBRASS\">Brass</link>"
msgstr "<link=\"SOLIDBRASS\">Latón</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDFIBERGLASS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDFIBERGLASS.DESC"
msgid ""
"Fiberglass is a thermoset polymer matrix made by a poltrusion of boronsilicate <link=\"GLASS\">Glass</link> and <link=\"POLYPROPYLENE\">Plastic</link>. Although the fiber is weak in compression, this composite material has moderate insulating properties, and can be easily used in many different applications due to "
"its relative flexibility."
msgstr ""
"La fibra de vidrio es una matriz de polímero termoestable hecha por pultrusión de <link=\"GLASS\">Vidrio</link> de borosilicato y <link=\"POLYPROPYLENE\">Plástico</link>. Aunque la fibra es débil a la compresión, este material compuesto tiene propiedades aislantes moderadas y puede utilizarse fácilmente en muchas "
"aplicaciones diferentes debido a su relativa flexibilidad."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDFIBERGLASS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDFIBERGLASS.NAME"
msgid "<link=\"SOLIDFIBERGLASS\">Fiberglass</link>"
msgstr "<link=\"SOLIDFIBERGLASS\">Fibra de Vidrio</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDNITROGEN.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDNITROGEN.DESC"
msgid "(N<sub>2</sub>) Nitrogen is a nonmetal and the lightest member of group 15 of the periodic table, currently its its cold, solid state."
msgstr "(N<sub>2</sub>) El nitrógeno es un no metal y el miembro más ligero del grupo 15 de la tabla periódica, actualmente en su estado sólido y frío."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDNITROGEN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDNITROGEN.NAME"
msgid "<link=\"SOLIDNITROGEN\">Solid Nitrogen</link>"
msgstr "<link=\"SOLIDNITROGEN\">Nitrógeno Sólido</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDOILSHALE.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDOILSHALE.DESC"
msgid "Oil shale is an organic-rich fine-grained sedimentary rock containing heavy crude oil, sulfur compounds and heavy metals."
msgstr "El esquisto bituminoso es una roca sedimentaria de grano fino rica en materia orgánica que contiene petróleo crudo pesado, compuestos de azufre y metales pesados."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDOILSHALE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDOILSHALE.NAME"
msgid "<link=\"SOLIDOILSHALE\">Oil Shale</link>"
msgstr "<link=\"SOLIDOILSHALE\">Esquisto Bituminoso</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSILVER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSILVER.DESC"
msgid "(Ag) Silver is soft, white, lustrous transition metal, that exhibits a high electrical and thermal conductivity."
msgstr "(Ag) La plata es un metal de transición suave, blanco y brillante, que exhibe una alta conductividad eléctrica y térmica."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSILVER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSILVER.NAME"
msgid "<link=\"SOLIDSILVER\">Silver</link>"
msgstr "<link=\"SOLIDSILVER\">Plata</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSLAG.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSLAG.DESC"
msgid "Slag is a by-product of smelting (pyrometallurgical) ores and used metals. Despite being a waste product, it has many applications, such as aggregate in <link=\"CONCRETEBLOCK\">Concrete Blocks</link>."
msgstr "La escoria es un subproducto de la fundición (pirometalúrgica) de minerales y metales usados. A pesar de ser un producto de desecho, tiene muchas aplicaciones, como agregado en <link=\"CONCRETEBLOCK\">Bloques de Hormigón</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSLAG.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDSLAG.NAME"
msgid "<link=\"SOLIDSLAG\">Slag</link>"
msgstr "<link=\"SOLIDSLAG\">Escoria</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDVEGEOIL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDVEGEOIL.DESC"
msgid "Frozen solid oil extracted from vegetable biomass, composed of triglycerides and monounsaturated fatty acids."
msgstr "Aceite sólido congelado extraído de biomasa vegetal, compuesto por triglicéridos y ácidos grasos monoinsaturados."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDVEGEOIL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDVEGEOIL.NAME"
msgid "<link=\"SOLIDVEGEOIL\">Frozen Vegetable Oil</link>"
msgstr "<link=\"SOLIDVEGEOIL\">Aceite Vegetal Congelado</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDZINC.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDZINC.DESC"
msgid "(Zn) Zinc is a bluish-white, lustrous, diamagnetic metal, slightly brittle metal."
msgstr "(Zn) El zinc es un metal diamagnético, brillante, de color blanco azulado, un metal ligeramente quebradizo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDZINC.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOLIDZINC.NAME"
msgid "<link=\"SOLIDZINC\">Zinc</link>"
msgstr "<link=\"SOLIDZINC\">Zinc</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOURWATER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOURWATER.DESC"
msgid "An aqueous solution of Hydrogen Sulfide (H<sub>2</sub>S) and Ammonia (NH<sub>3</sub>). May occur naturally from aquifers exposed to hydrogen sulfide sources, but it is more common as a wastewater from industrial processes."
msgstr "Una solución acuosa de Sulfuro de Hidrógeno (H<sub>2</sub>S) y Amoníaco (NH<sub>3</sub>). Puede ocurrir naturalmente de acuíferos expuestos a fuentes de sulfuro de hidrógeno, pero es más común como agua residual de procesos industriales."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOURWATER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SOURWATER.NAME"
msgid "<link=\"SOURWATER\">Sour Water</link>"
msgstr "<link=\"SOURWATER\">Agua Agria</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SULFURICGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SULFURICGAS.DESC"
msgid "(H<sub>2</sub>SO<sub>4</sub>) An acidic gas composed of the elements sulfur, oxygen and hydrogen. Presented in its gaseous state, it is a very dangerous chemical for its corrosive nature."
msgstr "(H<sub>2</sub>SO<sub>4</sub>) Un gas ácido compuesto por los elementos azufre, oxígeno e hidrógeno. Presentado en su estado gaseoso, es un producto químico muy peligroso por su naturaleza corrosiva."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SULFURICGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.SULFURICGAS.NAME"
msgid "<link=\"SULFURICGAS\">Sulfuric Gas</link>"
msgstr "<link=\"SULFURICGAS\">Gas Sulfúrico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICCLAY.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICCLAY.DESC"
msgid "A sick looking, brittle clay produced as waste product from industrial operations, composed of many different chemical substances."
msgstr "Una arcilla quebradiza de aspecto enfermizo producida como producto de desecho de operaciones industriales, compuesta de muchas sustancias químicas diferentes."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICCLAY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICCLAY.NAME"
msgid "<link=\"TOXICCLAY\">Toxic Clay</link>"
msgstr "<link=\"TOXICCLAY\">Arcilla Tóxica</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICGAS.DESC"
msgid "A heavy, foul smelling gas produced as waste product from industrial operations, composed of many different chemical substances."
msgstr "Un gas pesado y maloliente producido como producto de desecho de operaciones industriales, compuesto de muchas sustancias químicas diferentes."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICGAS.NAME"
msgid "<link=\"TOXICGAS\">Toxic Gas</link>"
msgstr "<link=\"TOXICGAS\">Gas Tóxico</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICSLURRY.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICSLURRY.DESC"
msgid "A thick, toxic slurry produced as waste product from industrial operations, composed of many different chemical substances."
msgstr "Una suspensión espesa y tóxica producida como producto de desecho de operaciones industriales, compuesta de muchas sustancias químicas diferentes."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICSLURRY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.TOXICSLURRY.NAME"
msgid "<link=\"TOXICSLURRY\">Toxic Slurry</link>"
msgstr "<link=\"TOXICSLURRY\">Suspensión Tóxica</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.VEGEOILGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.VEGEOILGAS.DESC"
msgid "Gaseous oil extracted from vegetable biomass, composed of triglycerides and monounsaturated fatty acids."
msgstr "Aceite gaseoso extraído de biomasa vegetal, compuesto por triglicéridos y ácidos grasos monoinsaturados."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.VEGEOILGAS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.VEGEOILGAS.NAME"
msgid "<link=\"VEGEOILGAS\">Oily Gas</link>"
msgstr "<link=\"VEGEOILGAS\">Gas Aceitoso</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ZINCGAS.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ELEMENTS.ZINCGAS.DESC"
