msgstr "<link=\"SIMPLEFRIDGE\">Domácí lednice</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.DESC"
msgid ""
"An advanced biological vat that grows a culture of mucopolysaccharides and multicelular fungi mould. This unit also uses advanced filter "
"to extract Polluted Oxygen from its surroundings, albeit its not necessary for it to function."
msgstr ""
"Pokročilá biologická nádoba, která pěstuje kulturu mukopolysacharidů a mnohobuněčné houbové plísně. Tato jednotka také využívá pokročilý "
"filtr k extrakci znečištěného kyslíku ze svého okolí, i když to není pro její fungování nutné."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.EFFECT"
msgid ""
"Slime Vat needs <link=\"WATER\">Water</link> and <link=\"MUSHBAR\">Mush Bar</link> to grow, producing <link=\"SLIMEMOLD\">Slime</link> "
"outgrowth that is collected from the botton. Due to its nature, the slime its produce will be contaminated with Slimelung."
msgstr ""
"Slizová nádoba potřebuje k růstu <link=\"WATER\">vodu</link> a <link=\"MUSHBAR\">houbovou kaši</link>, přičemž produkuje výrůstky "
"<link=\"SLIMEMOLD\">slizu</link>, které jsou sbírány ze spodní části. Kvůli své povaze bude vyprodukovaný sliz kontaminován slizovou "
"chorobou Slimelung."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SLIMEVAT.NAME"
msgid "<link=\"SLIMEVAT\">Slime Vat</link>"
msgstr "<link=\"SLIMEVAT\">Slizová nádoba</link>"

