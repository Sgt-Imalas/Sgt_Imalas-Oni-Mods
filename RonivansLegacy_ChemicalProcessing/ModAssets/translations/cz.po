msgid "Unlocks the ability to drill into previously unreachable layers of the asteroid for resource extraction."
msgstr "Odemyká možnost vrtat do dříve nedostupných vrstev asteroidu za účelem těžby surovin."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.NAME"
msgid "<link=\"MININGMK2DRILLTECH\">Deep Core Mining</link>"
msgstr "<link=\"MININGMK2DRILLTECH\">Hlubinná těžba</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.DESC"
msgid "Enables fabrication of <style=\"KKeyword\">Simple Drillbits</style> at the <link=\"CRAFTINGTABLE\">Crafting Station</link>"
msgstr "Umožňuje výrobu <style=\"KKeyword\">jednoduchých vrtáků</style> v zařízení <link=\"CRAFTINGTABLE\">Výrobní stanice</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.NAME"
msgid "<style=\"KKeyword\">Simple Drillbit</style> Pattern"
msgstr "<style=\"KKeyword\">Jednoduchý vrták</style> – plánek"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.NAME"
msgid "Anaerobic Digester Natgas Multiplier"
msgstr "Multiplikátor produkce zemního plynu anaerobního vyhnívače"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.TOOLTIP"
msgid "Multiply the natural gas output amounts of the anaerobic digester by this value."
msgstr "Vynásobí množství zemního plynu produkovaného anaerobním vyhnívačem touto hodnotou."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.NAME"
msgid "Expeller Press Oil Multiplier"
msgstr "Expelerový lis – multiplikátor produkce oleje"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.TOOLTIP"
msgid "Multiply the vegetable oil output amounts of the expeller press by this value."
msgstr "Vynásobí množství rostlinného oleje produkovaného expelerovým lisem touto hodnotou."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.NAME"
msgid "Expeller Press Rebalance"
msgstr "Převyvážení expelerového lisu"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.TOOLTIP"
msgid ""
"Rebalances the yield of the Expeller Press Recipes to yield larger amounts of oil and biomass.\n"
"This give the building a better purpose, as its current yields are quite low, compared to the seakomb, which has its balance defined by "
"the game.\n"
"Turn off to get the old yields back"
msgstr ""
"Převyváží výtěžnost receptů expelerového lisu tak, aby poskytoval větší množství oleje a biomasy.\n"
"Díky tomu má budova lepší využití, protože její současné výnosy jsou ve srovnání se Seakombem poměrně nízké, zatímco ten má své vyvážení "
"definované hrou.\n"
"Vypněte pro návrat ke starým výnosům"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME"
msgid "Open Building Configuration Editor"
msgstr "Otevřít editor konfigurace budovy"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME_ALT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME_ALT"
msgid "Configure Mod Buildings"
msgstr "Konfigurovat modované budovy"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.TOOLTIP"
msgid ""
"Open the building editor to individually toggle all buildings added by the mod and change settings on some.\n"
"All changes done here require a restart!"
msgstr ""
"Otevře editor budov, kde lze jednotlivě zapínat a vypínat všechny budovy přidané modem a měnit nastavení některých z nich.\n"
"Všechny provedené změny vyžadují restart!"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.FORMAT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.FORMAT"
msgid "0 MJ"
msgstr "0 MJ"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.NAME"
msgid "Arc Furnace Thermal Capacitor Size"
msgstr "Velikost tepelného kondenzátoru obloukové pece"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.TOOLTIP"
msgid "The total heat capacity of the arc-furnace's internal thermal capacitor"
msgstr "Celková tepelná kapacita vnitřního tepelného kondenzátoru obloukové pece"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.NAME"
msgid "Arc Furnace Thermal Fudge"
msgstr "Tepelná korekce obloukové pece"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.TOOLTIP"
msgid ""
"The selective arc furnace only puts a percentage of its recipes heat into its internal heat capacitor.\n"
"The default value for the mod is 90%"
msgstr ""
"Selektivní oblouková pec předává pouze určité procento tepla z receptů do svého vnitřního tepelného zásobníku.\n"
"Výchozí hodnota tohoto modu je 90 %"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.NAME"
msgid "Metal Refinery Thermal Fudge"
msgstr "Tepelná korekce kovové rafinerie"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.TOOLTIP"
msgid ""
"The Metal refinery only puts a percentage of its recipes heat into the coolant.\n"
"The vanilla value for this is 80%.\n"
"The default value for the mod is 60%"
msgstr ""
"Kovová rafinerie předává pouze určité procento tepla ze svých receptů do chladicí kapaliny.\n"
"Vanilla hodnota je 80 %.\n"
"Výchozí hodnota tohoto modu je 60 %"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.NAME"
msgid "Advanced Refinery Thermal Fudge"
msgstr "Tepelná korekce pokročilé rafinerie"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.TOOLTIP"
msgid ""
"The Advanced Metal refinery only puts a percentage of its recipes heat into the coolant.\n"
"The default value for the mod is 90%"
msgstr ""
"Pokročilá kovová rafinerie předává pouze určité procento tepla ze svých receptů do chladicí kapaliny.\n"
"Výchozí hodnota tohoto modu je 90 %"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.NAME"
msgid "Move all Reservoirs to their piping category"
msgstr "Přesunout všechny zásobníky do jejich kategorie potrubí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.TOOLTIP"
msgid ""
"Moves all vanilla and mod reservoirs into the respective piping category:\n"
"Liquid Reservoirs are found under \"Plumbing\"\n"
"Gas Reservoirs are found under\"Ventilation\""
msgstr ""
"Přesune všechny vanilkové i modované zásobníky do příslušné kategorie potrubí:\n"
"Zásobníky kapalin se nacházejí v části „Instalatérství“\n"
"Zásobníky plynů se nacházejí v části „Ventilace“"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.NAME"
msgid "All Walls hide pipes"
msgstr "Všechny stěny skrývají potrubí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.TOOLTIP"
msgid "Like with the mod \"Drywall hides Pipes\", all backwall buildings are rendered in front of pipes and wires."
msgstr "Stejně jako u modu „Drywall hides Pipes“ jsou všechny budovy na zadní stěně vykreslovány před potrubím a elektrickými kabely."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.NAME"
msgid "Enable Mod Content"
msgstr "Povolit obsah modu"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP"
msgid ""
"The mod is enabled, this includes buildings, research, recipes and other mod specific mechanics.\n"
"You can still disable individual buildings of the mod in the building configuration editor, separate from this setting."
msgstr ""
"Mod je povolen. To zahrnuje budovy, výzkum, recepty a další mechaniky specifické pro mod.\n"
"Jednotlivé budovy modu lze stále vypnout v editoru konfigurace budov, nezávisle na tomto nastavení."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP_ELEMENTS
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP_ELEMENTS"
msgid ""
"The mod is enabled, this includes buildings, research, recipes, elements, comets and other mod specific mechanics.\n"
"You can still disable individual buildings of the mod in the building editor, separate from this setting.\n"
"Warning: when this mod is enabled, worldgen will be altered by new elements"
msgstr ""
"Mod je povolen. To zahrnuje budovy, výzkum, recepty, prvky, komety a další mechaniky specifické pro mod.\n"
"Jednotlivé budovy modu lze stále vypnout v editoru budov, nezávisle na tomto nastavení.\n"
"Upozornění: pokud je tento mod povolen, generování světa bude změněno o nové prvky"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.NAME"
msgid "Mod Geysers spawn from worldgen"
msgstr "Gejzíry modu se generují při vytváření světa"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.TOOLTIP"
msgid ""
"New Geysers are added to the pool of randomly spawned geysers.\n"
"This will affect worldgen if active (different random geysers are chosen compared to vanilla)\n"
"Turning it off will prevent those geysers from showing up from worldgen naturally unless you use a different mod to add them manually "
"(e.g. customize geyser or CGM)\n"
"\n"
"Revealing a random geyser (those spawned on classic asteroids and by the geoactive trait) in an already existing world WILL be affected "
"by this, turn off this option if you don't want existing saves to be affected."
msgstr ""
"Nové gejzíry jsou přidány do sady náhodně generovaných gejzírů.\n"
"Pokud je tato možnost aktivní, ovlivní generování světa (budou vybírány jiné náhodné gejzíry než ve vanile).\n"
"Vypnutí zabrání tomu, aby se tyto gejzíry přirozeně objevovaly při generování světa, pokud je nepřidá jiný mod ručně (např. Customize "
"Geyser nebo CGM).\n"
"\n"
"Zobrazování náhodných gejzírů (těch, které se generují na klasických asteroidech a pomocí vlastnosti geoactive) v již existujícím světě "
"bude touto možností ovlivněno. Pokud nechcete, aby byly ovlivněny stávající savy, tuto možnost vypněte."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.NAME"
msgid "High Pressure Gas Capacity Multiplier"
msgstr "Multiplikátor kapacity plynu při vysokém tlaku"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.TOOLTIP"
msgid ""
"High pressure gas pipes allow pumping gases at much higher pipe throughput than regular pipes, at the cost of more expensive building "
"materials.\n"
"Total Capacity is calculated based on the base pipe capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Vysokotlaké plynové potrubí umožňuje čerpat plyny s výrazně vyšší průtočnou kapacitou než běžné potrubí, za cenu použití dražších "
"stavebních materiálů.\n"
"Celková kapacita se vypočítává na základě základní kapacity potrubí (včetně kompatibility s modifikací CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.NAME"
msgid "Base Wattage: High Pressure Gas Pump"
msgstr "Základní příkon: vysokotlaké plynové čerpadlo"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.TOOLTIP"
msgid ""
"The total pump wattage is calculated by multiplying the base wattage value with the respective pipe capacity multiplier (compared to "
"regular pipes)"
msgstr ""
"Celkový příkon čerpadla se vypočítá vynásobením základní hodnoty příkonu příslušným multiplikátorem kapacity potrubí (ve srovnání s "
"běžným potrubím)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.NAME"
msgid "High Pressure Liquid Capacity Multiplier"
msgstr "Multiplikátor kapacity vysokotlakého kapalného potrubí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.TOOLTIP"
msgid ""
"High pressure liquid pipes allow pumping liquids at much higher pipe throughput than regular pipes, at the cost of more expensive "
"building materials.\n"
"Total Capacity is calculated based on the base pipe capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Vysokotlaké kapalné potrubí umožňuje čerpat kapaliny s výrazně vyšší průtočnou kapacitou než běžné potrubí, za cenu použití dražších "
"stavebních materiálů.\n"
"Celková kapacita se vypočítává na základě základní kapacity potrubí (včetně kompatibility s modifikací CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.NAME"
msgid "Base Wattage: High Pressure Liquid Pump"
msgstr "Základní příkon: vysokotlaké kapalinové čerpadlo"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.TOOLTIP"
msgid ""
"The total pump wattage is calculated by multiplying the base wattage value with the respective pipe capacity multiplier (compared to "
"regular pipes)"
msgstr ""
"Celkový příkon čerpadla se vypočítá vynásobením základní hodnoty příkonu příslušným multiplikátorem kapacity potrubí (ve srovnání s "
"běžným potrubím)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.NAME"
msgid "Heavy-Duty Auto-Sweeper Range"
msgstr "Dosah těžkoodolného automatického sběrače"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.TOOLTIP"
msgid ""
"The Heavy-Duty Auto-Sweeper serves as a late game version of the autosweeper, having higher range and throughput at the cost of more "
"complex build requirements"
msgstr ""
"Těžkoodolný automatický sběrač slouží jako pozdně herní verze autosběrače, s vyšším dosahem a průchodností za cenu složitějších "
"stavebních požadavků"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.NAME"
msgid "Heavy-Duty Rail Capacity Multiplier"
msgstr "Multiplikátor kapacity těžkoodolné železnice"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.TOOLTIP"
msgid ""
"Heavy-Duty Rails serve as an late game upgrade to conveyor rails, having a much higher throughput at the cost of more complex build "
"requirements.\n"
"Total Capacity is calculated based on the base rail capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Těžkoodolné koleje slouží jako pozdně herní vylepšení dopravních kolejí, s výrazně vyšší průchodností za cenu složitějších stavebních "
"požadavků.\n"
"Celková kapacita se vypočítává na základě základní kapacity kolejí (včetně kompatibility s modifikací CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.NAME"
msgid "Enable Heavy-Duty Rails"
msgstr "Povolit těžkoodolné koleje"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.TOOLTIP"
msgid ""
"Heavy-Duty Rails serve as an late game upgrade to conveyor rails, having a much higher throughput at the cost of more complex build "
"requirements."
msgstr ""
"Těžkoodolné koleje slouží jako pozdně herní vylepšení dopravních kolejí s výrazně vyšší průchodností za cenu složitějších stavebních "
"požadavků."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.NAME"
msgid "Insulated Heavy-Duty Rails"
msgstr "Izolované těžkoodolné koleje"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.TOOLTIP"
msgid ""
"Enable an insulated variant of the heavy-duty conveyor rail.\n"
"Toggling this option also toggles all patches related to changing the insulation state of rail items, so it is not recommended to disable "
"it for games with existing insulated rails."
msgstr ""
"Povolí izolovanou variantu těžkoodolné dopravní koleje.\n"
"Přepnutí této možnosti také zapíná/vypíná všechny záplaty související se změnou izolačního stavu předmětů na kolejích, proto se "
"nedoporučuje ji vypínat u her s již existujícími izolovanými kolejemi."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.NAME"
msgid "Overheat Immune High-Pressure-Pumps"
msgstr "Vysokotlaká čerpadla odolná vůči přehřátí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.TOOLTIP"
msgid ""
"Makes high pressure pumps immune to overheating.\n"
"(Restores old behavior for existing save compatibility)"
msgstr ""
"Zajišťuje, že vysokotlaká čerpadla jsou imunní vůči přehřívání.\n"
"(Obnovuje původní chování pro kompatibilitu se stávajícími uloženými pozicemi)"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.NAME"
msgid "Logistic Rail Capacity Multiplier"
msgstr "Multiplikátor kapacity logistických kolejí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.TOOLTIP"
msgid ""
"Logistic Rails serve as an early game version to conveyor rails, lacking the mechatronic requirements and unlocking earlier at the cost "
"of lower maximum throughput.\n"
"Total Capacity is calculated based on the base rail capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Logistické koleje slouží jako raná verze dopravních kolejí, bez mechatronických požadavků a odemykají se dříve, avšak za cenu nižší "
"maximální průchodnosti.\n"
"Celková kapacita se vypočítává na základě základní kapacity kolejí (včetně kompatibility s modifikací CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.NAME"
msgid "Logistic Auto-Sweeper Range"
msgstr "Dosah logistického automatického sběrače"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.TOOLTIP"
msgid ""
"The Logistic Auto-Sweeper serves as an early game version of the autosweeper, trading reduced carrying capacity for a lack of a "
"mechatronics requirement."
msgstr ""
"Logistický automatický sběrač slouží jako raná verze automatického sběrače, výměnou za sníženou přepravní kapacitu nemá požadavek na "
"mechatroniku."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_LOADER
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_LOADER"
msgid "No Self Heating: Logistic Loader"
msgstr "Bez vlastního zahřívání: logistický nakladač"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_SWEEPER
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_SWEEPER"
msgid "No Self Heating: Logistic Sweeper"
msgstr "Bez vlastního zahřívání: logistický sběrač"

