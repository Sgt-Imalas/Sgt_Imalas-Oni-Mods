#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.DESC"
msgid "A sturdy and durable ladder wrought from refined metals."
msgstr "Pevný a odolný žebřík vyrobený z rafinovaných kovů."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.EFFECT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.AIO_METALLADDER.EFFECT"
