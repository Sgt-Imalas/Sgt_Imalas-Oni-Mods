"Boils <link=\"WATER\">Water</link> to <link=\"STEAM\">Steam</link> at 200 °C. This particular boiler uses "
"<link=\"COMBUSTIBLEGAS\">Combustible Gases</link> as fuel."
msgstr ""
"Vaří <link=\"WATER\">vodu</link> na <link=\"STEAM\">páru</link> při 200 °C. Tento kotel využívá jako palivo "
"<link=\"COMBUSTIBLEGAS\">hořlavé plyny</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_GAS_BOILER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_GAS_BOILER.NAME"
msgid "<link=\"CHEMICALGASBOILER\">Gas-fueled Steam Boiler</link>"
msgstr "<link=\"CHEMICALGASBOILER\">Plynový parní kotel</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.CHEMICAL_GLASSFOUNDRY.DESC
