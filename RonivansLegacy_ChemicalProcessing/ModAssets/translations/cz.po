#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDING.STATUSITEMS.AIO_ADVREFINERY_NOSUPERCOOLANT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDING.STATUSITEMS.AIO_ADVREFINERY_NOSUPERCOOLANT.NAME"
msgid "Thermal Throttling active!"
msgstr "Aktivní teplotní omezení výkonu!"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDING.STATUSITEMS.AIO_ADVREFINERY_NOSUPERCOOLANT.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDING.STATUSITEMS.AIO_ADVREFINERY_NOSUPERCOOLANT.TOOLTIP"
msgid ""
"The use of a lower-grade coolant has caused this refinery to throttle its refinement speed.\n"
"Changing to Supercoolant will resolve this issue."
msgstr ""
"Použití méně kvalitního chladiva způsobilo, že tato rafinerie omezila rychlost zpracování.\n"
"Přechod na superchladivo tento problém vyřeší."

