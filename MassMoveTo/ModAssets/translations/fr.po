#. MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.NAME
msgctxt "MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.NAME"
msgid "Mass Relocate Here"
msgstr "Déplacement en masse ici"

#. MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.TITLE
msgctxt "MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.TITLE"
msgid "Experimental: use Multi-Delivery Targets"
msgstr "Experimental: use Multi-Delivery Targets"

#. MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.TOOLTIP
msgctxt "MassMoveTo.STRINGS.MISC.PLACERS.MMT_MULTIMOVEPICKUPABLEPLACER.TOOLTIP"
msgid ""
"Replaces the Relocate targets with a custom modded variant that allows "
"multiple deliveries in parallel.\n"
"Turn off if you experience crashes"
msgstr ""
"Remplace les cibles de déplacement en masse par une variante personnalisée "
"modifiée qui permet d'effectuer plusieurs livraisons en parallèle.\n"
"Désactivez cette option si vous rencontrez des crashes"

