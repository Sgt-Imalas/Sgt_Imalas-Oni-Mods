#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_BUNKERDOWN.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_BUNKERDOWN.NAME"
msgid "Bunkered down"
msgstr "Ukrytý v bunkru"

#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_BUNKERDOWN.TOOLTIP
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_BUNKERDOWN.TOOLTIP"
msgid "This radiator is currently protected from meteor impacts."
msgstr "Tento radiátor je momentálně chráněn před dopady meteorů."

#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_INSPACERADIATING.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_INSPACERADIATING.NAME"
msgid "Radiating {0}"
msgstr "Vyzařuje {0}"

#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_INSPACERADIATING.TOOLTIP
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_INSPACERADIATING.TOOLTIP"
msgid ""
"This radiator is currently radiating heat at {0} with {AREAPERCENTAGE}% of its area."
msgstr ""
"Tento radiátor aktuálně vyzařuje teplo rychlostí {0} při využití {AREAPERCENTAGE}% "
"své plochy."

#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_NOTINSPACE.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_NOTINSPACE.NAME"
msgid "Not in space"
msgstr "Není ve vesmíru"

#. Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_NOTINSPACE.TOOLTIP
msgctxt "Radiator_Mod.STRINGS.BUILDING.STATUSITEMS.RM_NOTINSPACE.TOOLTIP"
msgid ""
"This radiators panels are not exposed to space, thus it won't radiate any heat away."
msgstr ""
"Panely tohoto radiátoru nejsou vystaveny vesmíru, a proto nemůže vyzařovat žádné "
"teplo do okolního prostoru."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.DESC
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.DESC"
msgid "Radiates off heat energy into space as infrared radiation."
msgstr "Vyzařuje tepelnou energii do vesmíru ve formě infračerveného záření."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.EFFECT
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.EFFECT"
msgid ""
"Exchanges heat with the liquid pumped through it.\n"
"\n"
"If in space, radiates off infrared energy based off the Stefan–Boltzmann law."
msgstr ""
"Vyměňuje teplo s kapalinou, která jím protéká.\n"
"\n"
"Pokud je vystaven vesmíru, vyzařuje infračervenou energii podle Stefanova–"
"Boltzmannova zákona."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORBASE.NAME"
msgid "Space Radiator"
msgstr "Vesmírný radiátor"

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.DESC
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.DESC"
msgid "Radiates off heat energy into space as infrared radiation."
msgstr "Vyzařuje tepelnou energii do vesmíru ve formě infračerveného záření."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.EFFECT
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.EFFECT"
msgid ""
"Exchanges heat with the liquid pumped through it.\n"
"\n"
"If in space, radiates off infrared energy based off the Stefan–Boltzmann law."
msgstr ""
"Vyměňuje teplo s kapalinou, která jím protéká.\n"
"\n"
"Pokud je ve vesmíru, vyzařuje infračervenou energii podle Stefanova–Boltzmannova "
"zákona."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RADIATORUPDATED.NAME"
msgid "Space Radiator"
msgstr "Vesmírný radiátor"

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.DESC
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.DESC"
msgid "Radiates off heat energy into space as infrared radiation."
msgstr "Vyzařuje tepelnou energii do vesmíru ve formě infračerveného záření."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.EFFECT
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.EFFECT"
msgid ""
"Exchanges heat with the liquid pumped through it.\n"
"\n"
"If in space, radiates off infrared energy based off the Stefan–Boltzmann law.\n"
"\n"
"Has to be attached to the rocket interior wall."
msgstr ""
"Vyměňuje teplo s kapalinou, která jím protéká.\n"
"\n"
"Pokud je ve vesmíru, vyzařuje infračervenou energii podle Stefanova–Boltzmannova "
"zákona.\n"
"\n"
"Musí být připevněn k vnitřní stěně rakety."

#. Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.NAME
msgctxt "Radiator_Mod.STRINGS.BUILDINGS.PREFABS.RM_RADIATORROCKETWALLBUILDABLE.NAME"
msgid "Space Radiator (Rocket)"
msgstr "Vesmírný radiátor (raketa)"

#. Radiator_Mod.STRINGS.MODCONFIG.DELETIONMULTIPLIER.NAME
msgctxt "Radiator_Mod.STRINGS.MODCONFIG.DELETIONMULTIPLIER.NAME"
msgid "Radiation Multiplier"
msgstr "Násobitel vyzařování"

#. Radiator_Mod.STRINGS.MODCONFIG.DELETIONMULTIPLIER.TOOLTIP
msgctxt "Radiator_Mod.STRINGS.MODCONFIG.DELETIONMULTIPLIER.TOOLTIP"
msgid ""
"Set a custom multiplier that affects the radiation rate.\n"
"1 is the scientificially most accurate value."
msgstr ""
"Nastavte vlastní násobitel ovlivňující rychlost vyzařování.\n"
"Hodnota 1 odpovídá vědecky nejpřesnějšímu nastavení."

#. Radiator_Mod.STRINGS.MODCONFIG.OLDFORMULA.NAME
msgctxt "Radiator_Mod.STRINGS.MODCONFIG.OLDFORMULA.NAME"
msgid "Old Functionality (v2.2.1 and earlier)"
msgstr "Původní funkčnost (verze 2.2.1 a starší)"

#. Radiator_Mod.STRINGS.MODCONFIG.OLDFORMULA.TOOLTIP
msgctxt "Radiator_Mod.STRINGS.MODCONFIG.OLDFORMULA.TOOLTIP"
msgid ""
"restore the old deletion method that made the radiator up to 5x as powerful as "
"intended for low shc materials"
msgstr ""
"Obnoví původní metodu výpočtu, která způsobovala, že radiátor byl při použití "
"materiálů s nízkou měrnou tepelnou kapacitou až pětkrát účinnější, než bylo "
"zamýšleno."
